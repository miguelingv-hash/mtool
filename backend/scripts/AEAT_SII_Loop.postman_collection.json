{
  "info": {
    "name": "AEAT SII - ConsultaLRFacturasEmitidas (Loop)",
    "description": "Colección que itera la paginación de ConsultaLRFacturasEmitidas hasta vaciar el periodo. Cada factura se imprime como línea CSV en consola con cabeceras según el XSD. Para volcar a fichero, ejecutar con Newman:\n\n  newman run \"AEAT_SII_Loop.postman_collection.json\" -e env.json --reporter-cli-no-summary --reporter-cli-no-failures > export.txt 2>&1\n\nLa cabecera CSV ('CSVHEAD:') y las filas ('CSVROW:') se filtran tras la ejecución con:\n  findstr /B \"CSV\" export.txt > facturas.csv   (Windows)\n  grep '^CSV' export.txt > facturas.csv         (Linux/Mac)\n\nIMPORTANTE: para mTLS, en Postman Desktop ve a Settings → Certificates → Add Certificate → asocia tu .pfx (convertido a .crt/.key) al host www1.agenciatributaria.gob.es. En Newman pasa --ssl-client-cert-pfx <archivo.pfx> --ssl-client-passphrase <pass>.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "endpoint",       "value": "https://www1.agenciatributaria.gob.es/wlpl/SSII-FACT/ws/fe/SiiFactFEV1SOAP" },
    { "key": "endpoint_test",  "value": "https://prewww1.aeat.es/wlpl/SSII-FACT/ws/fe/SiiFactFEV1SOAP" },
    { "key": "use_test",       "value": "true" },
    { "key": "nif",            "value": "A95000295" },
    { "key": "razon_social",   "value": "TotalEnergies Clientes S.A.U." },
    { "key": "ejercicio",      "value": "2026" },
    { "key": "periodo",        "value": "05" },
    { "key": "clave_pag",      "value": "" },
    { "key": "pagina",         "value": "0" },
    { "key": "acumuladas",     "value": "0" },
    { "key": "csv_header_done","value": "false" }
  ],
  "item": [
    {
      "name": "ConsultaLRFacturasEmitidas - Loop",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// === PRE-REQUEST: construye el SOAP envelope con paginación ===",
              "const nif    = pm.variables.get('nif');",
              "const razon  = pm.variables.get('razon_social');",
              "const ej     = pm.variables.get('ejercicio');",
              "const per    = pm.variables.get('periodo');",
              "const clave  = pm.variables.get('clave_pag') || '';",
              "",
              "// Selecciona endpoint según use_test (Postman no soporta ternarios en {{...}})",
              "const useTest = String(pm.variables.get('use_test')).toLowerCase() === 'true';",
              "const url = useTest ? pm.variables.get('endpoint_test') : pm.variables.get('endpoint');",
              "pm.variables.set('soap_url', url);",
              "",
              "let clavePag = '';",
              "if (clave) {",
              "  try {",
              "    const c = JSON.parse(clave);",
              "    clavePag = `<siiLR:ClavePaginacion>",
              "      <sii:IDEmisorFactura><sii:NIF>${c.NIF}</sii:NIF></sii:IDEmisorFactura>",
              "      <sii:NumSerieFacturaEmisor>${c.NumSerieFacturaEmisor}</sii:NumSerieFacturaEmisor>",
              "      <sii:FechaExpedicionFacturaEmisor>${c.FechaExpedicionFacturaEmisor}</sii:FechaExpedicionFacturaEmisor>",
              "    </siiLR:ClavePaginacion>`;",
              "  } catch (e) { console.error('clave_pag inválida:', e); }",
              "}",
              "",
              "const envelope = `<?xml version='1.0' encoding='UTF-8'?>",
              "<soapenv:Envelope xmlns:soapenv='http://schemas.xmlsoap.org/soap/envelope/'",
              "  xmlns:sii='https://www2.agenciatributaria.gob.es/static_files/common/internet/dep/aplicaciones/es/aeat/ssii/fact/ws/SuministroInformacion.xsd'",
              "  xmlns:siiLR='https://www2.agenciatributaria.gob.es/static_files/common/internet/dep/aplicaciones/es/aeat/ssii/fact/ws/ConsultaLR.xsd'>",
              "  <soapenv:Body>",
              "    <siiLR:ConsultaLRFacturasEmitidas>",
              "      <sii:Cabecera>",
              "        <sii:IDVersionSii>1.1</sii:IDVersionSii>",
              "        <sii:Titular>",
              "          <sii:NombreRazon>${razon}</sii:NombreRazon>",
              "          <sii:NIF>${nif}</sii:NIF>",
              "        </sii:Titular>",
              "      </sii:Cabecera>",
              "      <siiLR:FiltroConsulta>",
              "        <sii:PeriodoLiquidacion>",
              "          <sii:Ejercicio>${ej}</sii:Ejercicio>",
              "          <sii:Periodo>${per}</sii:Periodo>",
              "        </sii:PeriodoLiquidacion>",
              "        ${clavePag}",
              "      </siiLR:FiltroConsulta>",
              "    </siiLR:ConsultaLRFacturasEmitidas>",
              "  </soapenv:Body>",
              "</soapenv:Envelope>`;",
              "",
              "pm.variables.set('soap_body', envelope);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "// === TEST: parsea la respuesta y vuelca facturas a consola en CSV ===",
              "const xml = pm.response.text();",
              "if (pm.response.code !== 200) {",
              "  console.error('HTTP', pm.response.code, xml.substring(0, 500));",
              "  return;",
              "}",
              "",
              "// Cabeceras CSV alineadas con RegistroRespuestaConsultaLRFacturasEmitidas (XSD AEAT)",
              "const HEADERS = [",
              "  'PeriodoEjercicio','PeriodoPeriodo',",
              "  'IDEmisorFacturaNIF','IDEmisorFacturaNombre',",
              "  'NumSerieFacturaEmisor','NumSerieFacturaEmisorFin',",
              "  'FechaExpedicionFacturaEmisor',",
              "  'TipoFactura','ClaveRegimenEspecial','ImporteTotal','DescripcionOperacion',",
              "  'FechaOperacion','BaseImponible','TipoImpositivo','CuotaRepercutida',",
              "  'ContraparteNIF','ContraparteNombre','EstadoFactura',",
              "  'CSVAEAT','NumRegistroPresentacion','TimestampPresentacion'",
              "];",
              "",
              "if (pm.variables.get('csv_header_done') !== 'true') {",
              "  console.log('CSVHEAD:' + HEADERS.join('|'));",
              "  pm.variables.set('csv_header_done', 'true');",
              "}",
              "",
              "// Extractor sencillo de texto entre tags (sin DOM en Postman sandbox)",
              "function tag(scope, name) {",
              "  const re = new RegExp('<(?:[a-zA-Z0-9]+:)?' + name + '[^>]*>([^<]*)</(?:[a-zA-Z0-9]+:)?' + name + '>');",
              "  const m = scope.match(re);",
              "  return m ? m[1].trim() : '';",
              "}",
              "function clean(v) { return String(v).replace(/[|\\r\\n]+/g, ' ').trim(); }",
              "",
              "// Localiza todos los <RegistroRespuestaConsultaLRFacturasEmitidas>...</...>",
              "const reReg = /<(?:[a-zA-Z0-9]+:)?RegistroRespuestaConsultaLRFacturasEmitidas[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?RegistroRespuestaConsultaLRFacturasEmitidas>/g;",
              "let match, count = 0;",
              "while ((match = reReg.exec(xml)) !== null) {",
              "  const r = match[1];",
              "  const idFact = (r.match(/<(?:[a-zA-Z0-9]+:)?IDFactura[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?IDFactura>/) || [])[1] || '';",
              "  const idEmis = (idFact.match(/<(?:[a-zA-Z0-9]+:)?IDEmisorFactura[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?IDEmisorFactura>/) || [])[1] || '';",
              "  const datos  = (r.match(/<(?:[a-zA-Z0-9]+:)?DatosFacturaEmitida[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?DatosFacturaEmitida>/) || [])[1] || '';",
              "  const contra = (datos.match(/<(?:[a-zA-Z0-9]+:)?Contraparte[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?Contraparte>/) || [])[1] || '';",
              "  const periodo = (r.match(/<(?:[a-zA-Z0-9]+:)?PeriodoImputacion[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?PeriodoImputacion>/) || [])[1] || '';",
              "  const estado = (r.match(/<(?:[a-zA-Z0-9]+:)?EstadoFactura[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?EstadoFactura>/) || [])[1] || '';",
              "  const desglose = (datos.match(/<(?:[a-zA-Z0-9]+:)?DetalleIVA[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?DetalleIVA>/) || [])[1] || '';",
              "",
              "  const fila = [",
              "    tag(periodo,'Ejercicio'), tag(periodo,'Periodo'),",
              "    tag(idEmis,'NIF'), tag(idEmis,'NombreRazon'),",
              "    tag(idFact,'NumSerieFacturaEmisor'), tag(idFact,'NumSerieFacturaEmisorFin'),",
              "    tag(idFact,'FechaExpedicionFacturaEmisor'),",
              "    tag(datos,'TipoFactura'), tag(datos,'ClaveRegimenEspecialOTrascendencia'),",
              "    tag(datos,'ImporteTotal'), tag(datos,'DescripcionOperacion'),",
              "    tag(datos,'FechaOperacion'), tag(desglose,'BaseImponible'),",
              "    tag(desglose,'TipoImpositivo'), tag(desglose,'CuotaRepercutida'),",
              "    tag(contra,'NIF'), tag(contra,'NombreRazon'),",
              "    tag(estado,'EstadoRegistro'),",
              "    tag(r,'CSV'), tag(r,'NumRegistroPresentacion'), tag(r,'TimestampPresentacion')",
              "  ].map(clean);",
              "  console.log('CSVROW:' + fila.join('|'));",
              "  count++;",
              "}",
              "",
              "// Paginación: lee IndicadorPaginacion + datos de la última factura como nueva ClavePaginacion",
              "const indic = tag(xml, 'IndicadorPaginacion');",
              "let acumuladas = parseInt(pm.variables.get('acumuladas') || '0') + count;",
              "let pagina     = parseInt(pm.variables.get('pagina') || '0') + 1;",
              "pm.variables.set('acumuladas', acumuladas.toString());",
              "pm.variables.set('pagina', pagina.toString());",
              "console.log(`PAGE:${pagina} +${count} facturas (acumuladas=${acumuladas}) indic=${indic}`);",
              "",
              "if (indic === 'S' && count > 0) {",
              "  // Toma la última factura para construir la ClavePaginacion siguiente",
              "  const lastMatch = [...xml.matchAll(reReg)].pop();",
              "  if (lastMatch) {",
              "    const lr = lastMatch[1];",
              "    const idF = (lr.match(/<(?:[a-zA-Z0-9]+:)?IDFactura[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?IDFactura>/) || [])[1] || '';",
              "    const idE = (idF.match(/<(?:[a-zA-Z0-9]+:)?IDEmisorFactura[^>]*>([\\s\\S]*?)<\\/(?:[a-zA-Z0-9]+:)?IDEmisorFactura>/) || [])[1] || '';",
              "    const clavePag = {",
              "      NIF: tag(idE,'NIF'),",
              "      NumSerieFacturaEmisor: tag(idF,'NumSerieFacturaEmisor'),",
              "      FechaExpedicionFacturaEmisor: tag(idF,'FechaExpedicionFacturaEmisor')",
              "    };",
              "    pm.variables.set('clave_pag', JSON.stringify(clavePag));",
              "    postman.setNextRequest('ConsultaLRFacturasEmitidas - Loop');",
              "  } else {",
              "    postman.setNextRequest(null);",
              "  }",
              "} else {",
              "  console.log(`DONE: descarga finalizada. Total facturas: ${acumuladas}`);",
              "  // DEBUG: si no salieron facturas, vuelca la respuesta cruda para inspección",
              "  if (acumuladas === 0) {",
              "    console.log('XMLDUMP_BEGIN');",
              "    console.log(xml.substring(0, 4000));",
              "    console.log('XMLDUMP_END');",
              "  }",
              "  postman.setNextRequest(null);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type",  "value": "text/xml; charset=utf-8" },
          { "key": "SOAPAction",    "value": "\"\"" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{{soap_body}}",
          "options": { "raw": { "language": "xml" } }
        },
        "url": {
          "raw": "{{soap_url}}",
          "host": ["{{soap_url}}"]
        }
      }
    }
  ]
}
