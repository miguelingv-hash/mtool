# Caddyfile — HTTPS automático con Let's Encrypt
#
# El email es necesario para el registro ACME (recibirás avisos de expiración).
{
    email miguelingv@gmail.com
}

# Hostname público. sslip.io resuelve automáticamente a 3.125.115.81
# (la IP está embebida en el propio hostname).
3-125-115-81.sslip.io {
    encode zstd gzip

    # Subidas grandes (PDFs, CSVs Newman de cientos de MB)
    request_body {
        max_size 600MB
    }

    # Cache fuerte para assets con hash (no para index.html)
    @static path_regexp \.(?:js|css|woff2?|ttf|otf|eot|svg|png|jpg|jpeg|gif|webp|ico)$
    header @static Cache-Control "public, max-age=2592000, immutable"

    # Healthcheck (responde antes que todo lo demás)
    handle /healthz {
        respond "ok" 200
    }

    # API → backend FastAPI (handle EXCLUSIVO, no continúa al siguiente bloque)
    handle /api/* {
        reverse_proxy backend:8001 {
            header_up X-Real-IP {remote_host}
            header_up X-Forwarded-For {remote_host}
            header_up X-Forwarded-Proto {scheme}

            # Timeouts amplios: hay endpoints que tardan (subidas de 200+ MB
            # con redes domésticas + parser CSV de 800 k filas). Sin esto
            # Caddy cierra la conexión al upstream y el cliente ve
            # ECONNABORTED a mitad de upload.
            transport http {
                dial_timeout 30s
                read_timeout 30m
                write_timeout 30m
                response_header_timeout 10m
            }
        }
    }

    # SPA — todo lo demás cae aquí (handle por defecto)
    handle {
        root * /usr/share/caddy
        try_files {path} /index.html
        file_server
    }
}
